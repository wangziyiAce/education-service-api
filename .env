APP_NAME=education-service-api
APP_ENV=development
APP_DEBUG=true

# MySQL 数据库连接
DATABASE_URL=mysql+pymysql://root:123456@127.0.0.1:3306/education_service?charset=utf8mb4

# JWT 密钥（生产环境请更换为随机字符串）
JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRE_HOURS=24

# Dify 配置
DIFY_API_BASE_URL=http://localhost/v1
DIFY_API_KEY=app-xxxxxxxxxxxxxxxx
DIFY_SERVICE_TOKEN=service-edu-agent-20260709
BACKEND_API_BASE_URL=http://host.docker.internal:8000

# 文件上传
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760
