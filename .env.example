# ==================== 应用配置 ====================
# APP_ENV 控制启动期数据库行为：development 才允许自动建缺失表和开发种子数据。
# 生产环境必须使用 production；无论何种环境，应用启动都不会执行 ALTER TABLE。
APP_ENV=development
APP_DEBUG=true
# 请生成并填入新的随机密钥；不要复用已提交过 .env 中的任何密钥。
JWT_SECRET_KEY=change-me-before-deploying

# ==================== 数据库 ====================
# 首选完整连接串。用户名、密码中的特殊字符需要 URL 编码。
DATABASE_URL=mysql+pymysql://app_user:change-me@localhost:3306/education_service?charset=utf8mb4

# 兼容旧部署：未配置 DATABASE_URL 时才读取以下分段变量。
DB_HOST=localhost
DB_PORT=3306
DB_USER=app_user
DB_PASSWORD=change-me
DB_NAME=education_service
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_ECHO=false

# ==================== JWT 认证 ====================
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==================== Dify / 报告 AI 解释 ====================
# local：不调用 LLM，使用本地确定性解释，并在 data_quality 中标记。
# llm：调用大模型（纯 Python 实现），REPORT_LLM_API_KEY 必须配置。
# REPORT_AI_MODE=dify 已废弃，请改用 llm。
REPORT_AI_MODE=local
DIFY_API_BASE_URL=http://localhost:5001/v1
DIFY_API_KEY=change-me
DIFY_SERVICE_TOKEN=change-me

# ==================== 智能报告模块 — 纯 Python LLM 配置 ====================
# 当 REPORT_AI_MODE=llm 时，以下变量决定大模型连接方式。
# 默认配置面向 DeepSeek；OpenAI、Qwen 等兼容接口只需改 BASE_URL 和 MODEL。
REPORT_LLM_PROVIDER=deepseek
REPORT_LLM_MODEL=deepseek-v4-pro
REPORT_LLM_BASE_URL=https://api.deepseek.com
REPORT_LLM_API_KEY=sk-your-deepseek-api-key
# REPORT_LLM_TIMEOUT  LLM 请求超时秒数，默认 180。
# REPORT_LLM_MAX_RETRIES  网络异常额外重试次数，默认 2，使用指数退避。
# REPORT_LLM_TIMEOUT=180
# REPORT_LLM_MAX_RETRIES=2

# 文件上传
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760


